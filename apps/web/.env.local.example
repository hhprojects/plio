# Supabase
# Local: http://127.0.0.1:54321 | Production: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
# Local: http://localhost:3000 | Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (production only — local dev uses Supabase Inbucket)
RESEND_API_KEY=

# QR Check-in (generate a random 32+ char secret for production)
CHECKIN_SECRET=
