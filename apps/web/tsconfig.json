{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@plio/ui": ["../../packages/ui/src"],
      "@plio/ui/*": ["../../packages/ui/src/*"],
      "@plio/db": ["../../packages/db/src"],
      "@plio/db/*": ["../../packages/db/src/*"],
      "@plio/utils": ["../../packages/utils/src"],
      "@plio/utils/*": ["../../packages/utils/src/*"]
    },
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
